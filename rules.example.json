{
  "$comment": "straightforward 代理规则配置示例",
  "$comment2": "规则从上到下匹配，第一条匹配的规则生效",

  "rules": [
    {
      "match": "geosite:category-ads-all",
      "upstream": {
        "host": "127.0.0.1",
        "port": 1084
      }
    },
    {
      "match": "geosite:gfw",
      "upstream": {
        "host": "127.0.0.1",
        "port": 1082
      }
    },
    {
      "match": "geosite:telegram",
      "upstream": {
        "host": "127.0.0.1",
        "port": 1083
      }
    },
    {
      "match": "geosite:twitter",
      "upstream": {
        "host": "127.0.0.1",
        "port": 1083
      }
    },
    {
      "match": "geosite:youtube",
      "upstream": {
        "host": "proxy-us.example.com",
        "port": 8080,
        "auth": {
          "user": "user1",
          "pass": "pass1"
        }
      }
    },
    {
      "match": "geosite:netflix",
      "upstream": {
        "host": "proxy-us.example.com",
        "port": 8080,
        "auth": {
          "user": "user1",
          "pass": "pass1"
        }
      }
    },
    {
      "match": "*.google.com",
      "upstream": {
        "host": "proxy-us.example.com",
        "port": 8080
      }
    },
    {
      "match": "geosite:openai",
      "upstream": {
        "host": "proxy-jp.example.com",
        "port": 3128,
        "auth": {
          "user": "user2",
          "pass": "pass2"
        }
      }
    },
    {
      "match": "geosite:anthropic",
      "upstream": {
        "host": "proxy-jp.example.com",
        "port": 3128,
        "auth": {
          "user": "user2",
          "pass": "pass2"
        }
      }
    },
    {
      "match": "geosite:github",
      "upstream": {
        "host": "proxy-jp.example.com",
        "port": 3128,
        "auth": {
          "user": "user2",
          "pass": "pass2"
        }
      }
    },
    {
      "match": "geosite:cn",
      "upstream": null
    },
    {
      "match": "geosite:apple-cn",
      "upstream": null
    },
    {
      "match": "geosite:google-cn",
      "upstream": null
    },
    {
      "match": "*.cn",
      "upstream": null
    },
    {
      "match": "192.168.*",
      "upstream": null
    },
    {
      "match": "10.*",
      "upstream": null
    },
    {
      "match": "172.16.*",
      "upstream": null
    },
    {
      "match": "*",
      "upstream": {
        "host": "127.0.0.1",
        "port": 1082
      }
    }
  ]
}
